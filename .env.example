# ============================================================
# SKU MANAGER — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ─── Database (Neon DB) ────────────────────────────────────
# Get from: https://console.neon.tech → Connection Details
# "pooled" connection for app, "direct" for migrations
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Clerk Authentication ──────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk sign-in/up redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Vercel Blob Storage ──────────────────────────────────
# Get from: https://vercel.com → Storage → Blob → Create Store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── App URL ──────────────────────────────────────────────
# Your deployed URL (used for API links in external connections)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
